{% set activeTranslation = snippet.translationByLocale(activeLocale) %}

{# Always show default locale + any selected references, deduplicated #}
{% set refLocales = [default_locale] %}
{% for locale in visibleReferenceLocales|default([]) %}
    {% if locale != default_locale and locale != activeLocale %}
        {% set refLocales = refLocales|merge([locale]) %}
    {% endif %}
{% endfor %}

<div class="card">
    <div class="card-header">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <twig:Xutim:Admin:Badge>{{ snippet.category.value }}</twig:Xutim:Admin:Badge>

            <a
                href="{{ admin_path('admin_snippet_edit', {id: snippet.id}) }}"
                data-turbo-frame="modal"
                class="fw-bold text-decoration-none"
            >{{ snippet.code }}</a>

            {% if snippet.description %}
                <span class="text-muted">
                    &mdash; {{ snippet.description }}
                </span>
            {% endif %}
        </div>
    </div>

    <div class="card-body">
        {# Reference translations (default locale always shown + selected extras) #}
        {% if activeLocale != default_locale or refLocales|length > 1 %}
            {% for refLocale in refLocales %}
                {% if refLocale != activeLocale %}
                    {% set refTranslation = snippet.translationByLocale(refLocale) %}
                    <div class="mb-2 p-2 rounded" style="background: var(--tblr-bg-surface-secondary);">
                        <div class="d-flex align-items-baseline gap-2">
                            <span class="badge bg-muted text-muted-fg flex-shrink-0">{{ refLocale|language_name|capitalize }}</span>
                            {% if refTranslation is not null %}
                                <span class="text-muted text-wrap">{{ refTranslation.content }}</span>
                            {% else %}
                                <span class="text-muted fst-italic">{{ 'No translation'|trans({}, 'admin') }}</span>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        {% endif %}

        <div class="d-flex align-items-start gap-2">
            <span class="badge bg-blue text-white mt-1">{{ activeLocale|upper }}</span>
            <textarea
                rows="2"
                class="form-control flex-grow-1"
                data-snippet-editor-target="input"
                data-action="blur->snippet-editor#save"
                data-snippet-id="{{ snippet.id }}"
                data-locale="{{ activeLocale }}"
                data-token="{{ csrf_token('translate_snippet_' ~ snippet.id ~ '_' ~ activeLocale) }}"
                {{ canTranslateLocale ? '' : 'disabled' }}
            >{{ activeTranslation.content ?? '' }}</textarea>
        </div>
    </div>
</div>
